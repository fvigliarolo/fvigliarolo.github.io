---
import AmbientBackground from "../components/AmbientBackground.astro";
import "@fontsource-variable/onest";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/code.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Federico Vigliarolo</title>
	</head>
	<body>
		<AmbientBackground />
		<div class="page-shell">
			<slot />
		</div>
	</body>
</html>

<style is:global>
	:root {
		--page-bg: #101c3d;
		--page-text: #d8d8d8;
		--page-accent: #50cbc7;
		--page-accent-soft: #4d7cff;
		--sidebar-width: clamp(18.5rem, 24vw, 22rem);
		--content-width: min(100%, 48.75rem);
		--content-offset: calc(var(--sidebar-width) + clamp(6rem, 6.8vw, 8rem));
		--page-shell-offset: clamp(14.96rem, 17.68vw, 18.105rem);
	}

	html,
	body {
		min-height: 100%;
		background-color: var(--page-bg);
		color: var(--page-text);
  		font-family: 'Onest Variable', sans-serif;
		line-height: inherit;
		font-weight: 100;
	}

	body {
		margin: 0;
		overflow-x: hidden;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	.page-shell {
		position: relative;
		z-index: 1;
		width: min(calc(100% - var(--page-shell-offset) - 2.5rem), 1600px);
		margin: 40px 0 40px var(--page-shell-offset);
	}

	::selection {
		background: rgba(80, 203, 199, 0.35);
	}

    @media (max-width: 768px) {
		.page-shell {
			margin: 0;
			width: 100%;
		}
	}
	/* Agregamos media querys para hasta 1300px */
	@media (max-width: 1300px) {
		:root {
			--sidebar-width: 100%;
			--content-width: 100%;
			--content-offset: 0;
		}

		.page-shell {
			margin: 0;
			width: 100%;
		}
	}
</style>
