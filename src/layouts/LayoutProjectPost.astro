---
import LayoutProjects from "./LayoutProjects.astro";
import ArrowLeft from "../components/icons/ArrowLeft.astro";
import Badge from "../components/Badge.astro";
import Link from "../components/icons/Link.astro";
import Github from "../components/icons/github.astro";

const { frontmatter } = Astro.props;
---

<LayoutProjects>
    <article class="project-post">
        <header class="project-header">
            <a href="../" class="back-link">
                <ArrowLeft class="arrowLeft" /> Projects
            </a>

            <div class="hero-copy">
                <div class="project-meta-top">
                    <div class="summary-group">
                        <p class="summary-value project-type-pill">{frontmatter.project_type}</p>
                    </div>

                    <div class="summary-group summary-inline">
                        <p class="summary-label">Scope</p>
                        <p class="summary-value project-goal">{frontmatter.goal}</p>
                    </div>
                </div>
                <h1>{frontmatter.title}</h1>
            </div>

            <div class="project-overview">
                <div class="links">
                    <ul>
                        {frontmatter.demo && frontmatter.demo !== "" && (
                            <li>
                                <a href={frontmatter.demo} target="_blank" rel="noreferrer">
                                    <Link class="iconLink" /> Demo
                                </a>
                            </li>
                        )}
                        {frontmatter.github && frontmatter.github.length > 0 && (
                            <li>
                                <a href={frontmatter.github[0]} target="_blank" rel="noreferrer">
                                    <Github class="iconLink" /> Github
                                </a>
                            </li>
                        )}
                    </ul>
                </div>

                <div class="summary-group technologies-group">
                    <p class="summary-label">Technologies</p>
                    <ul class="tecnologies">
                        {
                            frontmatter.tecnologies.map((tecnology) => (
                                <Badge>{tecnology}</Badge>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </header>

        <article class="project-body">
            <slot />
        </article>

        <section class="project-details">
            <div class="detail-block">
                <p class="detail-label">Tags</p>
                <ul class="tags">
                    {frontmatter.tags.map((tag) => <Badge class="tag">{tag}</Badge>)}
                </ul>
            </div>
        </section>
    </article>

    <style>
        .project-post {
            display: grid;
            gap: 2.4rem;
        }

        .project-header {
            display: grid;
            gap: 1.15rem;
            width: min(100%, 47rem);
            margin: 0 auto;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            width: fit-content;
            color: #d8d8d8;
            opacity: 0.92;
            transition: transform 220ms ease, color 220ms ease;
        }

        .back-link:hover {
            color: #50cbc7;
            transform: translateX(-4px);
        }

        .hero-copy {
            display: grid;
            gap: 0.45rem;
        }

        .project-meta-top {
            display: flex;
            flex-wrap: wrap;
            align-items: flex-start;
            justify-content: flex-end;
            gap: 1.1rem;
        }

        .project-overview {
            display: grid;
            grid-template-columns: auto minmax(18rem, 1fr);
            justify-content: space-between;
            gap: 1.5rem;
        }

        .links ul,
        .tecnologies,
        .tags {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.6rem;
            padding: 0;
            margin: 0;
        }

        .links li,
        .tags li {
            list-style: none;
        }

        .links a {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.62rem 0.9rem;
            border-radius: 999px;
            color: #d8d8d8;
            text-decoration: none;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(216, 216, 216, 0.08);
            transition:
                transform 220ms ease,
                border-color 220ms ease,
                color 220ms ease,
                background-color 220ms ease;
        }

        .links a:hover {
            color: #50cbc7;
            transform: translateY(-2px);
            border-color: rgba(80, 203, 199, 0.24);
            background: rgba(80, 203, 199, 0.08);
        }

        .iconLink {
            transition: transform 220ms ease;
        }

        .links a:hover .iconLink {
            transform: translateX(2px);
        }

        .summary-group {
            display: grid;
            gap: 0.35rem;
            width: 100%;
            justify-items: end;
            text-align: right;
        }

        .summary-inline {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            width: fit-content;
        }

        .summary-label {
            margin: 0;
            color: #d8d8d8;
            font-size: 0.74rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .summary-value {
            margin: 0;
            color: #d8d8d8ba;
        }

        .project-goal {
            color: #50cbc7;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .project-type {
            color: #d8d8d8;
            font-size: 0.92rem;
            letter-spacing: 0.02em;
        }

        .project-type-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            margin: 0;
            padding: 0.28rem 0.65rem;
            border-radius: 999px;
            color: #d8d8d8;
            font-size: 0.72rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(216, 216, 216, 0.1);
            white-space: nowrap;
        }

        .project-type-pill::before {
            content: "";
            width: 0.45rem;
            height: 0.45rem;
            border-radius: 50%;
            background: linear-gradient(135deg, #50cbc7, #4d7cff);
            box-shadow: 0 0 12px rgba(80, 203, 199, 0.3);
        }

        .tecnologies {
            justify-content: flex-end;
        }

        .project-body {
            width: min(100%, 47rem);
            margin: 0 auto;
        }

        .project-body :global(h2) {
            margin-top: 0;
            margin-bottom: 1rem;
            color: #d8d8d8;
            font-size: 1.28rem;
        }

        .project-body :global(p) {
            margin: 1rem 0;
            letter-spacing: 0.02em;
            line-height: 1.7;
            color: #d8d8d8ba;
        }

        .project-body :global(strong) {
            color: #d8d8d8;
        }

        .project-body :global(a) {
            color: #50cbc7;
            text-decoration: none;
        }

        .project-body :global(.references) {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            margin-top: 0.4rem;
            padding: 0.72rem 1rem;
            border-radius: 999px;
            color: #d8d8d8;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(216, 216, 216, 0.08);
            transition:
                transform 240ms ease,
                border-color 240ms ease,
                color 240ms ease,
                background-color 240ms ease,
                box-shadow 240ms ease,
                letter-spacing 240ms ease;
        }

        .project-body :global(.references:hover) {
            color: #50cbc7;
            transform: translateY(-3px) scale(1.01);
            border-color: rgba(80, 203, 199, 0.3);
            background: linear-gradient(135deg, rgba(80, 203, 199, 0.12), rgba(77, 124, 255, 0.08));
            box-shadow: 0 16px 30px rgba(7, 12, 31, 0.18);
            letter-spacing: 0.03em;
        }

        .project-body :global(.references .arrow-right) {
            transition: transform 240ms ease;
        }

        .project-body :global(.references:hover .arrow-right) {
            transform: translateX(4px);
        }

        .project-details {
            display: grid;
            gap: 1.4rem;
            width: min(100%, 47rem);
            margin: 0 auto;
            padding-top: 1.1rem;
            border-top: 1px solid rgba(216, 216, 216, 0.08);
        }

        .detail-block {
            display: grid;
            gap: 0.7rem;
        }

        .detail-label {
            margin: 0;
            color: #d8d8d8;
            font-size: 0.78rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .detail-value {
            margin: 0;
            color: #d8d8d8ba;
            letter-spacing: 0.02em;
        }

        @media (max-width: 768px) {
            .project-header,
            .project-body,
            .project-details {
                width: 100%;
            }

            .project-overview {
                display: grid;
                gap: 0.9rem;
                grid-template-columns: 1fr;
            }

            .project-meta-top {
                justify-content: flex-start;
                gap: 0.9rem;
            }

            .summary-group {
                justify-items: start;
                text-align: left;
            }

            .summary-inline {
                width: fit-content;
            }

            .tecnologies {
                justify-content: flex-start;
            }
        }
    </style>
</LayoutProjects>
