---
import LayoutProjects from "./LayoutProjects.astro";
import ArrowLeft from "../components/icons/ArrowLeft.astro";
import Badge from "../components/Badge.astro";
import Link from "../components/icons/Link.astro";
import Github from "../components/icons/github.astro";

const { frontmatter } = Astro.props;
---

<LayoutProjects>
    <article class="project-post">
        <header class="project-hero">
            <a href="../" class="back-link">
                <ArrowLeft class="arrowLeft" /> Projects
            </a>
            <div class="hero-copy">
                <p class="project-kicker">
                    <span>{frontmatter.goal}</span>
                    <span class="project-type">{frontmatter.project_type}</span>
                </p>
                <h1>{frontmatter.title}</h1>
            </div>
            <section class="project-overview">
                <div class="links">
                    <ul>
                        {frontmatter.demo && frontmatter.demo !== "" && (
                            <li>
                                <a href={frontmatter.demo} target="_blank" rel="noreferrer">
                                    <Link class="iconLink" /> Demo
                                </a>
                            </li>
                        )}
                        {frontmatter.github && frontmatter.github.length > 0 && (
                            <li>
                                <a href={frontmatter.github[0]} target="_blank" rel="noreferrer">
                                    <Github class="iconLink" /> Github
                                </a>
                            </li>
                        )}
                    </ul>
                </div>
                <ul class="tecnologies">
                    {
                        frontmatter.tecnologies.map((tecnology) => (
                            <Badge>{tecnology}</Badge>
                        ))
                    }
                </ul>
            </section>
        </header>

        <article class="project-body">
            <slot />

            <section class="project-tags">
                <h3>Tags</h3>
                <ul class="tags">
                    {frontmatter.tags.map((tag) => <Badge class="tag">{tag}</Badge>)}
                </ul>
            </section>
        </article>
    </article>

    <style>
        .project-post {
            display: grid;
            gap: 2rem;
        }

        .project-hero {
            display: grid;
            gap: 1.4rem;
            padding: 1.6rem 1.7rem;
            border: 1px solid rgba(216, 216, 216, 0.08);
            border-radius: 26px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.018)),
                rgba(12, 24, 56, 0.52);
            box-shadow: 0 24px 60px rgba(7, 12, 31, 0.18);
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            width: fit-content;
            color: #d8d8d8;
            opacity: 0.92;
            transition: transform 220ms ease, color 220ms ease;
        }

        .back-link:hover {
            color: #50cbc7;
            transform: translateX(-4px);
        }

        .hero-copy {
            display: grid;
            gap: 0.5rem;
        }

        .project-kicker {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.7rem;
            margin: 0;
            color: #50cbc7;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .project-type {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.28rem 0.65rem;
            border-radius: 999px;
            color: #d8d8d8;
            font-size: 0.72rem;
            letter-spacing: 0.08em;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(216, 216, 216, 0.1);
        }

        .project-type::before {
            content: "";
            width: 0.45rem;
            height: 0.45rem;
            border-radius: 50%;
            background: linear-gradient(135deg, #50cbc7, #4d7cff);
            box-shadow: 0 0 12px rgba(80, 203, 199, 0.3);
        }

        .project-overview {
            display: grid;
            gap: 1rem;
        }

        .links ul,
        .tecnologies,
        .tags {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 0.6rem;
            padding: 0;
            margin: 0;
        }

        .links li,
        .tags li {
            list-style: none;
        }

        .links a {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            padding: 0.72rem 1rem;
            border-radius: 999px;
            color: #d8d8d8;
            text-decoration: none;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(216, 216, 216, 0.08);
            transition:
                transform 220ms ease,
                border-color 220ms ease,
                color 220ms ease,
                background-color 220ms ease;
        }

        .links a:hover {
            color: #50cbc7;
            transform: translateY(-2px);
            border-color: rgba(80, 203, 199, 0.24);
            background: rgba(80, 203, 199, 0.08);
        }

        .iconLink {
            transition: transform 220ms ease;
        }

        .links a:hover .iconLink {
            transform: translateX(2px);
        }

        .project-body {
            width: min(100%, 47rem);
            margin: 0 auto;
        }

        .project-body :global(h2) {
            margin-top: 0;
            margin-bottom: 1rem;
            color: #d8d8d8;
            font-size: 1.28rem;
        }

        .project-body :global(p) {
            margin: 1rem 0;
            letter-spacing: 0.02em;
            line-height: 1.7;
            color: #d8d8d8ba;
        }

        .project-body :global(strong) {
            color: #d8d8d8;
        }

        .project-body :global(a) {
            color: #50cbc7;
            text-decoration: none;
        }

        .project-tags {
            margin-top: 2rem;
        }

        .project-tags h3 {
            margin-bottom: 1rem;
        }

        @media (max-width: 768px) {
            .project-hero {
                padding: 1.25rem;
                border-radius: 22px;
            }

            .project-body {
                width: 100%;
            }
        }
    </style>
</LayoutProjects>
