---
import AmbientBackground from "../components/AmbientBackground.astro";
import "@fontsource-variable/onest";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/code.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Federico Vigliarolo</title>
	</head>
	<body>
		<AmbientBackground />
		<div class="projects-shell">
			<slot />
		</div>
	</body>
</html>

<style is:global>
    :root {
        --page-bg: #101c3d;
        --page-text: #d8d8d8;
        --page-accent: #50cbc7;
        --page-accent-soft: #4d7cff;
    }

    html,
    body {
        min-height: 100%;
        background-color: var(--page-bg);
        color: var(--page-text);
        font-family: "Onest Variable", sans-serif;
        line-height: inherit;
        font-weight: 100;
    }
    body {
        margin: 0;
        overflow-x: hidden;
    }
    *,
    *::before,
    *::after {
        box-sizing: border-box;
    }
    .projects-shell {
        position: relative;
        z-index: 1;
        width: min(92%, 1040px);
        margin: 40px auto 64px;
    }
    h2{
        font-weight: 300;
    }
    h1 {
        margin-bottom: 20px;
        text-align: left;
    }
    a{
        color: var(--page-accent);
        text-decoration: none;

    }
    h3 a{
        color: #d8d8d8;
    }
    a:hover .arrowLeft{
        transform: translateX(-5px);
    }

    @media (max-width: 768px) {
        .projects-shell {
            margin: 0;
            width: 100%;
            padding: 1.25rem;
        }
        .tecnologies {
            flex-wrap: wrap;
        }
    }

    @media (max-width: 1300px){
        .projects-shell {
            width: min(94%, 1040px);
            margin: 24px auto 48px;
        }
    }
</style>
