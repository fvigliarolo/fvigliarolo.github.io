---
const { className = "" } = Astro.props;
---

<div class:list={["locale-switcher", className]} aria-label="Language selector">
    <button type="button" class="locale-option active" data-locale-button="en">EN</button>
    <span>/</span>
    <button type="button" class="locale-option" data-locale-button="es">ES</button>
</div>

<script is:inline>
    if (!window.__portfolioLocaleInitialized) {
        window.__portfolioLocaleInitialized = true;
        const localeStorageKey = "portfolio-locale";

        const getLocaleValue = (element, locale) => {
            return locale === "es" ? element.dataset.localeEs : element.dataset.localeEn;
        };

        const getStoredLocale = () => {
            const storedLocale = sessionStorage.getItem(localeStorageKey);
            return storedLocale === "es" ? "es" : "en";
        };

        const applyLocale = (locale) => {
            document.documentElement.lang = locale;
            sessionStorage.setItem(localeStorageKey, locale);

            document.querySelectorAll("[data-locale-en]").forEach((element) => {
                const value = getLocaleValue(element, locale) ?? element.dataset.localeEn;

                if (!value) {
                    return;
                }

                if (element.dataset.localeMode === "html") {
                    element.innerHTML = value;
                    return;
                }

                element.textContent = value;
            });

            document.querySelectorAll("[data-locale-button]").forEach((button) => {
                button.classList.toggle("active", button.dataset.localeButton === locale);
            });
        };

        window.__applyPortfolioLocale = applyLocale;

        const syncLocale = () => {
            window.__applyPortfolioLocale(getStoredLocale());
        };

        document.addEventListener("click", (event) => {
            const button = event.target.closest("[data-locale-button]");

            if (!button) {
                return;
            }

            window.__applyPortfolioLocale(button.dataset.localeButton);
        });

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", syncLocale, { once: true });
        } else {
            syncLocale();
        }

        window.addEventListener("pageshow", syncLocale);
    }
</script>

<style>
    .locale-switcher {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        color: #d8d8d8ba;
        font-size: 0.85rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .locale-option {
        border: 0;
        background: transparent;
        color: #d8d8d8ba;
        padding: 0;
        cursor: pointer;
        font: inherit;
        letter-spacing: inherit;
        text-transform: inherit;
        transition: color 180ms ease, transform 180ms ease;
    }

    .locale-option:hover {
        color: #d8d8d8;
        transform: translateY(-1px);
    }

    .locale-option.active {
        color: #50cbc7;
    }
</style>
