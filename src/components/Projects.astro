---
import ArrowRight from "./icons/ArrowRight.astro";
import projects from "../data/projects";
import Badge from "./Badge.astro";
---

<section id="projects" class="projects">
    <h3>Projects</h3>
    <ul>
        {
            projects.slice(0, 3).map(
                (project) => (
                    <li
                        onclick={`window.location.href='./projects/${project.id}'`}
                    >
                        <div class="project-data">
                            <div class="project-meta">
                                <span class="goal">{project.goal}</span>
                                <span class="project-type">{project.project_type}</span>
                            </div>
                            <p class="title">
                                {project.title} <ArrowRight class="arrow" />{" "}
                            </p>
                            <p class="description">{project.description}</p>
                            <ul class="tecnologies">
                                {project.tecnologies.map((tecnology) => (
                                    <Badge>{tecnology}</Badge>
                                ))}
                            </ul>
                        </div>
                    </li>
                ),
            )
        }
    </ul>
    <a href="./projects">See more projects <ArrowRight class="arrow" /> </a>
</section>

<style>
    .projects {
        width: 100%;
        max-width: 800px;
    }
    .project-data {
        margin-left: 0;
        display: grid;
        gap: 0.35rem;
        width: 100%;
    }
    .project-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.6rem;
        justify-content: space-between;
        width: 100%;
    }
    section {
        font-size: 0.875em; /* 14 px */
        color: #d8d8d8;
    }
    .projects > ul {
        display: grid;
        gap: 0.85rem;
        padding: 0;
        margin-bottom: 1.1rem;
    }
    .title {
        font-size: 1.12em;
        font-weight: 500;
        line-height: 1.35;
        display: inline-flex;
        align-items: center;
        margin-bottom: 0;
    }
    .title .arrow {
        padding-left: 3px;
        transition: padding-left 220ms ease;
    }
    .description {
        color: #d8d8d8ba;
        letter-spacing: 0.02em;
        width: 100%;
        max-width: none;
        margin-top: 0;
        margin-bottom: 0.15rem;
        line-height: 1.48;
    }
    a {
        display: inline-flex;
        text-decoration: none;
        align-items: center;
        color: #d8d8d8;
    }

    .projects > ul > li {
        list-style: none;
        display: block;
        width: 100%;
        margin: 0;
        padding: 0.9rem 1rem;
        box-sizing: border-box;
        border: 1px solid rgba(216, 216, 216, 0.08);
        border-radius: 18px;
        background:
            linear-gradient(135deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.018)),
            rgba(12, 24, 56, 0.45);
        transition:
            background-color 220ms ease,
            transform 220ms ease,
            border-color 220ms ease,
            box-shadow 220ms ease;
    }
    .projects > ul > li:hover {
        background:
            linear-gradient(135deg, rgba(80, 203, 199, 0.08), rgba(77, 124, 255, 0.04)),
            rgba(16, 28, 61, 0.78);
        cursor: pointer;
        transform: translateY(-4px);
        border-color: rgba(80, 203, 199, 0.22);
        box-shadow: 0 18px 40px rgba(7, 12, 31, 0.24);
    }
    .projects > ul > li:hover .arrow {
        padding-left: 8px;
    }
    .goal {
        display: inline-flex;
        align-items: center;
        color: #50cbc7;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 600;
    }
    .project-type {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.28rem 0.65rem;
        border-radius: 999px;
        color: #d8d8d8;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(216, 216, 216, 0.1);
        white-space: nowrap;
    }
    .project-type::before {
        content: "";
        width: 0.45rem;
        height: 0.45rem;
        border-radius: 50%;
        background: linear-gradient(135deg, #50cbc7, #4d7cff);
        box-shadow: 0 0 12px rgba(80, 203, 199, 0.3);
    }
    .projects > ul > li:hover .title {
        color: #50cbc7;
    }
    .tecnologies {
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
        margin: 0;
        width: 100%;
    }
    .tecnologies li {
        list-style: none;
    }
    a {
        font-weight: 500;
    }
    a:hover {
        color: #50cbc7;
    }
    a:hover .arrow {
        padding-left: 5px;
    }
    h3 {
        display: none;
    }
    @media (max-width: 768px) {
        h3 {
            display: block;
            color: #d8d8d8;
        }
        .project-meta {
            align-items: flex-start;
            flex-direction: column;
            gap: 0.55rem;
        }
    }

    @media (max-width: 1300px) {
        h3 {
            display: block;
            color: #d8d8d8;
        }
        .project-meta {
            align-items: flex-start;
        }
    }
</style>
