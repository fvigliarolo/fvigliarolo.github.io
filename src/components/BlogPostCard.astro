---
const { frontmatter, href } = Astro.props;
const description =
    frontmatter.excerpt ??
    "Technical notes, project stories, and lessons learned from real development work.";
---

<li onclick={`window.location.href='${href}'`}>
    <div class="post-data">
        <div class="post-meta">
            <span class="project-type">{frontmatter.project_type}</span>
            <span class="date">{frontmatter.date}</span>
        </div>
        <p class="title">{frontmatter.title}</p>
        <p class="description">{description}</p>
    </div>
</li>

<style>
    li {
        list-style: none;
        display: block;
        position: relative;
        width: 100%;
        margin: 0;
        padding: 0.9rem 1rem;
        box-sizing: border-box;
        border: 1px solid rgba(216, 216, 216, 0.08);
        border-radius: 18px;
        overflow: hidden;
        background:
            linear-gradient(135deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.018)),
            rgba(12, 24, 56, 0.45);
        transition:
            transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
            border-color 320ms ease,
            box-shadow 320ms ease,
            background 320ms ease;
    }

    li::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background:
            radial-gradient(circle at 12% 18%, rgba(80, 203, 199, 0.16), transparent 36%),
            radial-gradient(circle at 88% 82%, rgba(77, 124, 255, 0.14), transparent 32%);
        opacity: 0;
        transition:
            opacity 320ms ease,
            transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
        transform: scale(0.96);
        pointer-events: none;
    }

    li::after {
        content: "";
        position: absolute;
        inset: 1px;
        border-radius: calc(18px - 1px);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), transparent 28%);
        opacity: 0.45;
        pointer-events: none;
        transition: opacity 320ms ease;
    }

    li:hover {
        cursor: pointer;
        background:
            linear-gradient(135deg, rgba(80, 203, 199, 0.09), rgba(77, 124, 255, 0.05)),
            rgba(16, 28, 61, 0.82);
        transform: translateY(-5px) scale(1.01);
        border-color: rgba(80, 203, 199, 0.18);
        box-shadow:
            0 20px 44px rgba(7, 12, 31, 0.22),
            0 0 0 1px rgba(255, 255, 255, 0.03) inset;
    }

    li:hover::before {
        opacity: 1;
        transform: scale(1);
    }

    li:hover::after {
        opacity: 0.72;
    }

    li:hover .title {
        color: #50cbc7;
    }

    .post-data {
        display: grid;
        gap: 0.75rem;
        width: 100%;
        position: relative;
        z-index: 1;
    }

    .post-meta {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.6rem;
        justify-content: space-between;
        width: 100%;
        position: relative;
        z-index: 1;
    }

    .project-type {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.28rem 0.65rem;
        border-radius: 999px;
        color: #d8d8d8;
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(216, 216, 216, 0.1);
        white-space: nowrap;
    }

    .project-type::before {
        content: "";
        width: 0.45rem;
        height: 0.45rem;
        border-radius: 50%;
        background: linear-gradient(135deg, #50cbc7, #4d7cff);
        box-shadow: 0 0 12px rgba(80, 203, 199, 0.3);
    }

    .date {
        color: #50cbc7;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 600;
    }

    .title {
        font-size: 1.35em;
        font-weight: 600;
        line-height: 1.35;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        position: relative;
        z-index: 1;
        text-align: center;
    }

    .description {
        margin: 0;
        color: #d8d8d8ba;
        letter-spacing: 0.02em;
        line-height: 1.6;
        text-align: center;
        position: relative;
        z-index: 1;
    }

    @media (max-width: 768px) {
        .post-meta {
            align-items: flex-start;
            flex-direction: column;
            gap: 0.55rem;
        }
    }
</style>
