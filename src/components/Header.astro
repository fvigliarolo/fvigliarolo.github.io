---
import Github from "./icons/github.astro";
import Linkedin from "./icons/linkedin.astro";
import Gmail from "./icons/gmail.astro";
import Cv from "./icons/Cv.astro";
import Goodreads from "./icons/Goodreads.astro";
import Line from "./icons/Line.astro";

const navItems = [
    { title: { en: "About me ", es: "Sobre mi" }, label: "/about", url: "./#about", class: "options active" },
    { title: { en: "Projects", es: "Proyectos" }, label: "projects", url: "./#projects", class: "options"  },
    { title: { en: "Blog", es: "Blog" }, label: "/blog", url: "./#blog", class: "options"  },
];

const socialItems = [
    { title: "Github", url: "https://github.com/fvigliarolo" },
    {
        title: "Linkedin",
        url: "https://uy.linkedin.com/in/federico-vigliarolo-943b72201",
    },
    { title: "email", url: "mailto:fd.vigliarolo@gmail.com" },
    { title: "cv", url: "./FedericoVigliaroloResume.pdf" },
    {
        title: "Goodreads",
        url: "https://www.goodreads.com/user/show/191181530-federico-vigliarolo",
    },
];
---

<header>
    <div class="Description">
        <h1>Federico Vigliarolo</h1>
        <p><strong data-locale-en="Fullstack Developer" data-locale-es="Desarrollador Fullstack">Fullstack Developer</strong></p>
        <p
            data-locale-mode="html"
            data-locale-en="I build fullstack applications with javascript stack.<br class='hide-on-mobile'/>The lefting hours of the day, I work as a QA Engineer."
            data-locale-es="Construyo aplicaciones fullstack con stack javascript.<br class='hide-on-mobile'/>Durante las otras horas del dia, trabajo como QA Engineer."
        >
            I build fullstack applications with javascript stack.
            <br class="hide-on-mobile"/>
            The lefting hours of the day, I work as a QA Engineer.
        </p>
    </div>
    <nav>
        {
            navItems.map((item) => (
                <div class={item.class} data-nav-target={item.url} onclick="document.querySelectorAll('.options').forEach(el => el.classList.remove('active'));this.classList.add('active');">
                    <Line class="line"/>
                    <a href={item.url} class="nav-item">
                        <span data-locale-en={item.title.en} data-locale-es={item.title.es}>{item.title.en}</span>
                    </a>
                </div>
            ))
        }
    </nav>
    <div class="socialItems">
        {
            socialItems.map((item) => (
                <a
                    href={item.url}
                    class="social-item"
                    aria-label={item.title}
                    title={item.title}
                    target={item.title === "email" || item.title === "cv" ? undefined : "_blank"}
                    rel={item.title === "email" || item.title === "cv" ? undefined : "noreferrer"}
                >
                    {item.title === "Github" && <Github />}
                    {item.title === "Linkedin" && <Linkedin />}
                    {item.title === "email" && <Gmail />}
                    {item.title === "cv" && <Cv />}
                    {item.title === "Goodreads" && <Goodreads />}
                    <span class="social-label">{item.title}</span>
                </a>
            ))
        }
    </div>
</header>

<script>
    const easeInOutCubic = (t) =>
        t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

    const smoothScrollTo = (targetY, duration = 950) => {
        const startY = window.scrollY;
        const distance = targetY - startY;
        const startTime = performance.now();

        const step = (currentTime) => {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const easedProgress = easeInOutCubic(progress);

            window.scrollTo(0, startY + distance * easedProgress);

            if (progress < 1) {
                window.requestAnimationFrame(step);
            }
        };

        window.requestAnimationFrame(step);
    };

    document.querySelectorAll("[data-nav-target]").forEach((item) => {
        item.addEventListener("click", (event) => {
            const anchor = item.querySelector(".nav-item");
            const targetSelector = item.getAttribute("data-nav-target");

            if (!anchor || !targetSelector?.startsWith("./#")) {
                return;
            }

            const target = document.querySelector(targetSelector.replace("./", ""));

            if (!target) {
                return;
            }

            event.preventDefault();

            const targetY = target.getBoundingClientRect().top + window.scrollY - 24;
            smoothScrollTo(targetY);
            window.history.replaceState(null, "", targetSelector.replace("./", ""));
        });
    });

</script>

<style>
    .options{
        display: flex;
        flex-direction: row;
        align-items: center;
        height: 20px;
        transition: transform 220ms ease;
    }
    .options.active .nav-item{
        display: block;
        padding-right: 10px;
        cursor: pointer;
        color: #d8d8d8;
    }
    .options.active .line{
        display: block;
        height: 100px;
        padding-right: 10px;
        cursor: pointer;
        color: #d8d8d8;
    }
    .options .line{
        height: 30px;
        transition:
            height 240ms ease,
            color 240ms ease,
            opacity 240ms ease;
        opacity: 0.6;
    }
    .options:hover .line{
        display: block;
        height: 72px;
        padding-right: 10px;
        cursor: pointer;
        color: #d8d8d8;
        opacity: 1;

    }
    .options:hover .nav-item{
        color: #d8d8d8;
    }
    .options:hover {
        transform: translateX(4px);
    }
    header {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: flex-start;
        padding: 1rem;
        width: var(--sidebar-width);
        height: 75%;
        margin: 0 1%;
        overflow-y: hidden;
        position: fixed;
        z-index: 1000;
    }
    .Description {
        max-width: min(100%, 18.75rem);
        margin-bottom: 1.6rem;
    }
    h1 {
        font-size: 2.28rem;
        line-height: 1.15;
        margin: 0 0 0.35rem;
        letter-spacing: -0.03em;
        white-space: nowrap;
    }
    strong {
        font-size: 1.1rem;
    }

    nav {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 72px;
    }
    p {
        letter-spacing: 1px;
    }

    a {
        text-decoration: none;
        color: #d8d8d8ba;
    }
    .nav-item {
        transition:
            color 220ms ease,
            transform 220ms ease;
    }
    .options:hover .nav-item,
    .options.active .nav-item {
        transform: translateX(2px);
    }
    .socialItems {
        align-self: flex-start;
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
    }

    .socialItems a {
        margin: 0;
    }

    .socialItems a:hover {
        color: #d8d8d8;
    }
    .social-item {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(216, 216, 216, 0.08);
        transition:
            transform 180ms ease,
            background-color 180ms ease,
            border-color 180ms ease,
            color 180ms ease;
    }
    .social-item:hover {
        transform: translateY(-3px);
        color: #50cbc7;
        background: rgba(80, 203, 199, 0.08);
        border-color: rgba(80, 203, 199, 0.28);
    }
    .social-label {
        position: absolute;
        left: 50%;
        bottom: calc(100% + 0.7rem);
        top: auto;
        transform: translateX(-50%) translateY(6px);
        padding: 0.3rem 0.65rem;
        border-radius: 999px;
        background: rgba(12, 24, 56, 0.92);
        border: 1px solid rgba(216, 216, 216, 0.12);
        color: #d8d8d8;
        font-size: 0.8rem;
        white-space: nowrap;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition:
            opacity 180ms ease,
            transform 220ms ease,
            visibility 220ms ease;
    }
    .social-item:hover .social-label,
    .social-item:focus-visible .social-label {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
    }
    .social-item:focus-visible {
        outline: 2px solid rgba(80, 203, 199, 0.5);
        outline-offset: 4px;
    }
    @media (max-width: 1300px) {
        header {
            height: 20%;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: space-evenly;
            align-items: center;
            align-content: center;
            position: relative;
            width: 100%;
        }
        nav {
            display: none;

        }
        h1 {
            font-size: 2rem;
            text-align: center;
        }
        .Description {
            max-width: 34rem;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
        }
        p{
            text-align: center;
            margin-bottom: 0;
        }
        .hide-on-mobile
        {
            display: none;
        }
        strong {
            font-size: 1rem;
        }
        .socialItems {
            display: flex;
            flex-direction: row;
            justify-content: center;
            gap: 1rem;
            align-self: center;
            width: 100%;
        }
        .social-label {
            left: 50%;
            bottom: calc(100% + 0.7rem);
            top: auto;
            transform: translateX(-50%) translateY(6px);
        }
        .social-item:hover .social-label,
        .social-item:focus-visible .social-label {
            transform: translateX(-50%) translateY(0);
        }
    }
    @media (max-width: 768px) {
        header {
            height: 30%;
            margin: 0;
            margin-bottom: 20px;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            align-content: center;
            position: relative;
        }
        nav {
            display: none;

        }
        h1 {
            font-size: 1.4rem;
        }
        .Description {
            width: min(100%, 22rem);
            margin: 0 auto;
        }
        strong {
            font-size: 1rem;
        }

        .socialItems {
            display: flex;
            flex-direction: row;
            justify-content: center;
            gap: 1rem;
            align-self: center;
            margin-top: 20px;
            width: 100%;

        }
        .social-item {
            width: 2.55rem;
            height: 2.55rem;
        }
    }
</style>
