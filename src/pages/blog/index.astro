---
import LayoutProjects from "../../layouts/LayoutProjects.astro";
import ArrowLeft from "../../components/icons/ArrowLeft.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";

const allPosts = await Astro.glob("./*.md");
const posts = allPosts.sort((a, b) => b.frontmatter.id - a.frontmatter.id);
---

<LayoutProjects>
    <header class="blog-header">
        <a href="/" class="back-link">
            <ArrowLeft class="arrowLeft" /> Federico Vigliarolo
        </a>
        <h1>Blog</h1>
        <p class="intro">A space for technical notes, project stories, and lessons learned while building software.</p>
    </header>

    <section class="blog-list">
        <ul>
            {posts.map(({ frontmatter }) => (
                <BlogPostCard frontmatter={frontmatter} href={`/blog/${frontmatter.id}`} />
            ))}
        </ul>
    </section>
</LayoutProjects>

<style>
    .blog-header {
        display: grid;
        gap: 0.6rem;
        width: min(100%, 800px);
        margin: 0 auto 1.8rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        width: fit-content;
        color: #d8d8d8;
        opacity: 0.92;
        transition: transform 220ms ease, color 220ms ease;
    }

    .back-link:hover {
        color: #50cbc7;
        transform: translateX(-4px);
    }

    .intro {
        margin: 0;
        color: #d8d8d8ba;
        max-width: 680px;
        line-height: 1.6;
    }

    .blog-list {
        width: min(100%, 800px);
        margin: 0 auto;
    }

    .blog-list > ul {
        display: grid;
        gap: 1.08rem;
        padding: 0;
        margin: 0;
    }

    @media (max-width: 768px) {
        .blog-header,
        .blog-list {
            width: 100%;
        }
    }
</style>
